<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Chat with Penny — LittleInvestors</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/x-icon" href="/img/penny_logo.png">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script>
  (function(apiKey){
      (function(p,e,n,d,o){var v,w,x,y,z;o=p[d]=p[d]||{};o._q=o._q||[];
      v=['initialize','identify','updateOptions','pageLoad','track','trackAgent'];for(w=0,x=v.length;w<x;++w)(function(m){
      o[m]=o[m]||function(){o._q[m===v[0]?'unshift':'push']([m].concat([].slice.call(arguments,0)));};})(v[w]);
      y=e.createElement(n);y.async=!0;y.src='https://cdn.pendo.io/agent/static/'+apiKey+'/pendo.js';
      z=e.getElementsByTagName(n)[0];z.parentNode.insertBefore(y,z);})(window,document,'script','pendo');
  })('b441c372-5d2b-479f-8815-a8827f2cfb67');

  pendo.initialize({
    visitor: {
      id: ''
    }
  });
  </script>
</head>
<body style="overflow:hidden;height:100vh">

<div id="header">
  <a href="/home">
    <div class="header-left">
      <div id="coin"><img src="/img/coin.png" id="progressing" alt="coins"></div>
      <span class="coin-amount" id="coinAmount">800</span>
    </div>
    <div style="display:flex;align-items:center;gap:8px">
      <div style="width:10px;height:10px;background:#22c55e;border-radius:50%;animation:pulse 2s infinite"></div>
      <span style="font-size:14px;font-weight:700;color:#1a2332">Penny AI</span>
    </div>
    <div id="streak"><img src="/img/Vector 10.png" alt="streak"><h1 id="streakCount">30</h1></div>
  </a>
</div>

<style>
@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.6;transform:scale(1.2)}}
body{padding-bottom:0}
</style>

<div class="chat-wrapper">
  <div class="chat-window" id="chatWindow">
    <div class="msg-row">
      <div class="msg-avatar">🤖</div>
      <div>
        <div class="msg-bubble ai">Hi! I'm Penny, your AI money coach! 💰 I can explain anything about saving, investing, or spending. What would you like to learn about today?</div>
        <div class="msg-time">Now</div>
      </div>
    </div>
  </div>

  <div class="preset-chips" id="chips">
    <button class="chip" onclick="sendPreset('What is an allowance?')">💵 Allowance</button>
    <button class="chip" onclick="sendPreset('How do I save money?')">🐷 Saving</button>
    <button class="chip" onclick="sendPreset('What is a stock?')">📈 Stocks</button>
    <button class="chip" onclick="sendPreset('How do I budget?')">📊 Budget</button>
    <button class="chip" onclick="sendPreset('What is investing?')">🌱 Investing</button>
  </div>

  <div class="chat-input-row">
    <input type="text" class="chat-input" id="chatInput" placeholder="Ask me anything about money..." onkeydown="if(event.key==='Enter')sendMessage()">
    <button class="send-btn" onclick="sendMessage()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<nav class="menu" style="position:fixed">
  <a href="/home"><img src="/img/menu (3).png" alt="home"><span class="menu-label">Home</span></a>
  <a href="/courses"><img src="/img/menu (4).png" alt="courses"><span class="menu-label">Learn</span></a>
  <a href="/chatbot" class="active"><img src="/img/menu (2).png" alt="chat"><span class="menu-label">Chat</span></a>
  <a href="/parent"><img src="/img/menu (1).png" alt="parent"><span class="menu-label">Parent</span></a>
</nav>

<script>
function getTime() {
  return new Date().toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
}

function addMsg(text, type) {
  const win = document.getElementById('chatWindow');
  const row = document.createElement('div');
  row.className = 'msg-row ' + (type === 'user' ? 'user' : '');
  row.innerHTML = type === 'user'
    ? `<div><div class="msg-bubble user">${text}</div><div class="msg-time" style="text-align:right">${getTime()}</div></div><div class="msg-avatar" style="background:#f1f5f9;font-size:16px">😊</div>`
    : `<div class="msg-avatar">🤖</div><div><div class="msg-bubble ai">${text}</div><div class="msg-time">${getTime()}</div></div>`;
  win.appendChild(row);
  win.scrollTop = win.scrollHeight;
}

function showTyping() {
  const win = document.getElementById('chatWindow');
  const el = document.createElement('div');
  el.className = 'msg-row'; el.id = 'typing';
  el.innerHTML = `<div class="msg-avatar">🤖</div><div class="typing-indicator"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div>`;
  win.appendChild(el); win.scrollTop = win.scrollHeight;
  return el;
}

let _isPreset = false;

async function sendMessage() {
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;
  const wasPreset = _isPreset;
  _isPreset = false;
  input.value = '';
  document.getElementById('chips').style.display = 'none';
  addMsg(msg, 'user');
  const typing = showTyping();
  try {
    const res = await fetch('/api/chat', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({message: msg})
    });
    const data = await res.json();
    typing.remove();
    addMsg(data.message, 'ai');
    try { if(window.pendo) window.pendo.track('chat_message_sent', { message_length: msg.length, is_preset: wasPreset, response_source: data.isFallback ? 'fallback' : 'ai' }); } catch(e) {}
  } catch(e) {
    typing.remove();
    addMsg("Oops! I'm having trouble connecting. Try again in a moment! 🔄", 'ai');
  }
}

function sendPreset(q) {
  _isPreset = true;
  document.getElementById('chatInput').value = q;
  sendMessage();
}
</script>
</body>
</html>