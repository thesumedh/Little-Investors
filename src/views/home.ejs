<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LittleInvestors — Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/main.css">
  <link rel="icon" type="image/x-icon" href="/img/penny_logo.png">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.3/dist/confetti.browser.min.js"></script>
  <script>
  (function(apiKey){
      (function(p,e,n,d,o){var v,w,x,y,z;o=p[d]=p[d]||{};o._q=o._q||[];
      v=['initialize','identify','updateOptions','pageLoad','track','trackAgent'];for(w=0,x=v.length;w<x;++w)(function(m){
      o[m]=o[m]||function(){o._q[m===v[0]?'unshift':'push']([m].concat([].slice.call(arguments,0)));};})(v[w]);
      y=e.createElement(n);y.async=!0;y.src='https://cdn.pendo.io/agent/static/'+apiKey+'/pendo.js';
      z=e.getElementsByTagName(n)[0];z.parentNode.insertBefore(y,z);})(window,document,'script','pendo');
  })('b441c372-5d2b-479f-8815-a8827f2cfb67');

  pendo.initialize({
    visitor: {
      id: ''
    }
  });
  </script>
  <style>
    .portfolio-gain{font-size:13px;font-weight:600;color:#2AA46A;margin-top:4px}
    .section-pad{padding:0 20px}
    .notifs-wrap{padding:0 20px;margin-bottom:4px}
  </style>
</head>
<body>

<div id="header">
  <a href="/profile">
    <div class="header-left">
      <div id="coin"><img src="/img/coin.png" id="progressing" alt="coins"></div>
      <span class="coin-amount" id="coinAmount">800</span>
    </div>
    <div class="star-container">
      <img class="star" src="/img/star.png" alt="level">
      <div class="level-number" id="levelNum">0</div>
    </div>
    <div class="progress-container">
      <div class="progress-bar"><div class="progress" id="progress"></div></div>
    </div>
    <div id="streak">
      <img src="/img/Vector 10.png" alt="streak">
      <h1 id="streakCount">30</h1>
    </div>
  </a>
</div>

<div id="balance">
  <h1>Your Current Balance</h1>
  <div class="cylinder">
    <h3 class="center" id="balanceDisplay">$<span id="balanceNum">0</span></h3>
    <div class="balance-sub">
      <div class="portfolio-gain" id="portfolioGain">📈 +$0.00 today</div>
      <a onclick="showToast('Full history coming soon! 📊')">View Full History</a>
    </div>
  </div>
</div>

<div class="notifs-wrap" id="notifWrap">
  <!-- Notifications loaded dynamically via JS -->
</div>

<div class="section-header">
  <div class="section-title-sm">📈 Real Stock Simulator</div>
  <a href="/parent" class="parent-btn">👨‍👩‍👧 Parent Mode</a>
</div>

<div class="stocks-list">
  <!-- Walmart -->
  <div class="stock" onclick="toggleStock('wmt')">
    <div class="stock-logo"><img src="/img/Walmart.png" alt="WMT"></div>
    <div class="stock-info"><div class="stock-ticker">WMT</div><div class="stock-name">Walmart</div></div>
    <div class="stock-right"><div class="stock-price" id="wmt-display-price">$80.94</div><div class="stock-change green" id="wmt-display-change">+$0.51 (+0.6%)</div></div>
  </div>
  <div class="stock-detail" id="detail-wmt">
    <div class="stock-detail-row"><span>Price</span><span style="font-weight:600" id="wmt-detail-price">$80.94</span></div>
    <div class="stock-detail-row"><span>You own</span><span style="font-weight:600" id="wmt-shares">0 shares</span></div>
    <div class="stock-detail-row"><span>Value</span><span style="font-weight:600;color:#2AA46A" id="wmt-value">$0.00</span></div>
    <div class="buy-sell-btns">
      <button class="btn-buy" onclick="buySell('wmt','buy')">Buy 1 Share</button>
      <button class="btn-sell" onclick="buySell('wmt','sell')">Sell</button>
    </div>
  </div>

  <!-- Apple -->
  <div class="stock" onclick="toggleStock('aapl')">
    <div class="stock-logo"><img src="/img/Apple.png" alt="AAPL"></div>
    <div class="stock-info"><div class="stock-ticker">AAPL</div><div class="stock-name">Apple</div></div>
    <div class="stock-right"><div class="stock-price" id="aapl-display-price">$226.80</div><div class="stock-change green" id="aapl-display-change">+$1.13 (+0.5%)</div></div>
  </div>
  <div class="stock-detail" id="detail-aapl">
    <div class="stock-detail-row"><span>Price</span><span style="font-weight:600" id="aapl-detail-price">$226.80</span></div>
    <div class="stock-detail-row"><span>You own</span><span style="font-weight:600" id="aapl-shares">0 shares</span></div>
    <div class="stock-detail-row"><span>Value</span><span style="font-weight:600;color:#2AA46A" id="aapl-value">$0.00</span></div>
    <div class="buy-sell-btns">
      <button class="btn-buy" onclick="buySell('aapl','buy')">Buy 1 Share</button>
      <button class="btn-sell" onclick="buySell('aapl','sell')">Sell</button>
    </div>
  </div>

  <!-- Amazon -->
  <div class="stock" onclick="toggleStock('amzn')">
    <div class="stock-logo"><img src="/img/Amazon.png" alt="AMZN"></div>
    <div class="stock-info"><div class="stock-ticker">AMZN</div><div class="stock-name">Amazon</div></div>
    <div class="stock-right"><div class="stock-price" id="amzn-display-price">$186.51</div><div class="stock-change green" id="amzn-display-change">+$4.55 (+2.5%)</div></div>
  </div>
  <div class="stock-detail" id="detail-amzn">
    <div class="stock-detail-row"><span>Price</span><span style="font-weight:600" id="amzn-detail-price">$186.51</span></div>
    <div class="stock-detail-row"><span>You own</span><span style="font-weight:600" id="amzn-shares">0 shares</span></div>
    <div class="stock-detail-row"><span>Value</span><span style="font-weight:600;color:#2AA46A" id="amzn-value">$0.00</span></div>
    <div class="buy-sell-btns">
      <button class="btn-buy" onclick="buySell('amzn','buy')">Buy 1 Share</button>
      <button class="btn-sell" onclick="buySell('amzn','sell')">Sell</button>
    </div>
  </div>

  <!-- Premium Stocks Wrapper -->
  <div id="premiumStocks" style="display:none">
    <!-- Google -->
    <div class="stock" onclick="toggleStock('googl')">
      <div class="stock-logo" style="background:#fff"><span style="font-size:24px;font-weight:900;color:#4285F4">G</span></div>
      <div class="stock-info"><div class="stock-ticker">GOOGL</div><div class="stock-name">Alphabet Inc.</div></div>
      <div class="stock-right"><div class="stock-price" id="googl-display-price">$175.40</div><div class="stock-change green" id="googl-display-change">+$2.10 (+1.2%)</div></div>
    </div>
    <div class="stock-detail" id="detail-googl">
      <div class="stock-detail-row"><span>Price</span><span style="font-weight:600" id="googl-detail-price">$175.40</span></div>
      <div class="stock-detail-row"><span>You own</span><span style="font-weight:600" id="googl-shares">0 shares</span></div>
      <div class="stock-detail-row"><span>Value</span><span style="font-weight:600;color:#2AA46A" id="googl-value">$0.00</span></div>
      <div class="buy-sell-btns">
        <button class="btn-buy" onclick="buySell('googl','buy')">Buy 1 Share</button>
        <button class="btn-sell" onclick="buySell('googl','sell')">Sell</button>
      </div>
    </div>

    <!-- Tesla -->
    <div class="stock" onclick="toggleStock('tsla')">
      <div class="stock-logo" style="background:#fff"><span style="font-size:24px;font-weight:900;color:#E82127">T</span></div>
      <div class="stock-info"><div class="stock-ticker">TSLA</div><div class="stock-name">Tesla Inc.</div></div>
      <div class="stock-right"><div class="stock-price" id="tsla-display-price">$180.20</div><div class="stock-change red" id="tsla-display-change">-$1.45 (-0.8%)</div></div>
    </div>
    <div class="stock-detail" id="detail-tsla">
      <div class="stock-detail-row"><span>Price</span><span style="font-weight:600" id="tsla-detail-price">$180.20</span></div>
      <div class="stock-detail-row"><span>You own</span><span style="font-weight:600" id="tsla-shares">0 shares</span></div>
      <div class="stock-detail-row"><span>Value</span><span style="font-weight:600;color:#2AA46A" id="tsla-value">$0.00</span></div>
      <div class="buy-sell-btns">
        <button class="btn-buy" onclick="buySell('tsla','buy')">Buy 1 Share</button>
        <button class="btn-sell" onclick="buySell('tsla','sell')">Sell</button>
      </div>
    </div>

    <!-- Microsoft -->
    <div class="stock" onclick="toggleStock('msft')">
      <div class="stock-logo" style="background:#fff"><span style="font-size:24px;font-weight:900;color:#F25022">M</span></div>
      <div class="stock-info"><div class="stock-ticker">MSFT</div><div class="stock-name">Microsoft Corp.</div></div>
      <div class="stock-right"><div class="stock-price" id="msft-display-price">$420.10</div><div class="stock-change green" id="msft-display-change">+$3.50 (+0.8%)</div></div>
    </div>
    <div class="stock-detail" id="detail-msft">
      <div class="stock-detail-row"><span>Price</span><span style="font-weight:600" id="msft-detail-price">$420.10</span></div>
      <div class="stock-detail-row"><span>You own</span><span style="font-weight:600" id="msft-shares">0 shares</span></div>
      <div class="stock-detail-row"><span>Value</span><span style="font-weight:600;color:#2AA46A" id="msft-value">$0.00</span></div>
      <div class="buy-sell-btns">
        <button class="btn-buy" onclick="buySell('msft','buy')">Buy 1 Share</button>
        <button class="btn-sell" onclick="buySell('msft','sell')">Sell</button>
      </div>
    </div>
  </div>

  <div class="lock-card" id="lockCard" onclick="unlockPremiumStocks()" style="cursor:pointer;transition:var(--tr)">
    <div style="font-size:22px">🔒</div>
    <div class="lock-text">Unlock more stocks to diversify!</div>
    <div class="lock-cost">🪙 150</div>
  </div>
</div>

<nav class="menu">
  <a href="/home" class="active"><img src="/img/menu (3).png" alt="home"><span class="menu-label">Home</span></a>
  <a href="/courses"><img src="/img/menu (4).png" alt="courses"><span class="menu-label">Learn</span></a>
  <a href="/chatbot"><img src="/img/menu (2).png" alt="chat"><span class="menu-label">Chat</span></a>
  <a href="/parent"><img src="/img/menu (1).png" alt="parent"><span class="menu-label">Parent</span></a>
</nav>

<div class="toast" id="toast"></div>

<script src="/js/script.js"></script>
</body>
</html>